<?xml version="1.0" encoding="UTF-8"?>
<project name="ChatProject" default="javadoc" basedir=".">
    <property name="src.dir" value="src/main/java" />
    <property name="doc.dir" value="doc" />

    <target name="clean-doc">
        <delete dir="${doc.dir}" />
    </target>

    <target name="javadoc" depends="clean-doc" description="Genera la documentacion javadoc del proyecto en la carpeta doc">
        <mkdir dir="${doc.dir}" />
        <javadoc sourcepath="${src.dir}" destdir="${doc.dir}" encoding="UTF-8" docencoding="UTF-8" charset="UTF-8">
            <packageset dir="${src.dir}">
                <include name="es/ubu/lsi/**"/>
            </packageset>
        </javadoc>
    </target>
</project>